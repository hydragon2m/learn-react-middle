# API URL Endpoint của Backend
VITE_API_URL=http://localhost:4000/api

# Chế độ xác thực: cookie (Session Cookie) hoặc token (JWT)
VITE_AUTH_MODE=cookie

# Bật/tắt Mock Service Worker (MSW) để giả lập API khi chưa có Backend
# Chỉ có tác dụng trong môi trường phát triển (DEV)
VITE_MSW_ENABLED=false
